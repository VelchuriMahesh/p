rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /qr/{ngoId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /screenshots/{donorUid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == donorUid;
    }

    match /proofs/{donorUid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == donorUid;
    }

    match /ngo-media/{ngoId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /certificates/{donorUid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == donorUid;
      allow write: if false;
    }
  }
}
